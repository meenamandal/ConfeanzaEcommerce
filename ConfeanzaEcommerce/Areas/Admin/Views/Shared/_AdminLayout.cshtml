<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - @ViewData["Title"] | ConfeanzaEcommerce</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background: #fdf2f8; margin: 0; }
        .stat-card { border: none; border-radius: 12px; }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="admin-sidebar d-flex flex-column p-3">
            <!-- Brand -->
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
               class="sidebar-brand text-decoration-none mb-4 d-flex align-items-center gap-2">
                <span style="background:rgba(255,255,255,.25);border-radius:8px;padding:4px 8px;font-size:.9rem;">
                    <i class="bi bi-bag-heart-fill text-white"></i>
                </span>
                <span>Confeanza <span style="color:#fbcfe8;">Admin</span></span>
            </a>

            <nav class="nav flex-column gap-1 flex-grow-1">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link px-3 py-2">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
                <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="nav-link px-3 py-2">
                    <i class="bi bi-box me-2"></i> Products
                </a>
                <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="nav-link px-3 py-2">
                    <i class="bi bi-grid me-2"></i> Categories
                </a>
                <a asp-area="Admin" asp-controller="Brands" asp-action="Index" class="nav-link px-3 py-2">
                    <i class="bi bi-award me-2"></i> Brands
                </a>
                <a asp-area="Admin" asp-controller="Stores" asp-action="Index" class="nav-link px-3 py-2">
                    <i class="bi bi-shop me-2"></i> Stores
                </a>
                <a asp-area="Admin" asp-controller="Deals" asp-action="Index" class="nav-link px-3 py-2">
                    <i class="bi bi-fire me-2"></i> Deals
                </a>
                <a asp-area="Admin" asp-controller="Coupons" asp-action="Index" class="nav-link px-3 py-2">
                    <i class="bi bi-ticket-perforated me-2"></i> Coupons
                </a>
                <a asp-area="Admin" asp-controller="Blogs" asp-action="Index" class="nav-link px-3 py-2">
                    <i class="bi bi-journal-text me-2"></i> Blogs
                </a>
            </nav>

            <div class="mt-auto">
                <hr class="sidebar-divider my-2" />
                <a asp-controller="Home" asp-action="Index" asp-area="" class="nav-link px-3 py-2">
                    <i class="bi bi-arrow-left-circle me-2"></i> View Site
                </a>
            </div>
        </div>

        <!-- Main area -->
        <div class="admin-main">
            <!-- Top bar -->
            <div class="admin-topbar d-flex justify-content-between align-items-center px-4 py-3 mb-4 rounded-3 shadow-sm">
                <div>
                    <h5 class="fw-bold mb-0" style="color:#be185d;">@ViewData["Title"]</h5>
                    <small class="text-muted">ConfeanzaEcommerce Admin Panel</small>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge" style="background:#ec4899;padding:6px 14px;border-radius:20px;">
                        <i class="bi bi-shield-check me-1"></i>Admin
                    </span>
                </div>
            </div>

            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
