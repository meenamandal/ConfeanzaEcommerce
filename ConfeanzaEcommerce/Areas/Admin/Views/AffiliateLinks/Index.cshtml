@model List<AffiliateLink>
@{
    ViewData["Title"] = "Manage Prices";
    var product = ViewBag.Product as Product;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Products
    </a>
    <div>
        <h5 class="mb-0 fw-bold">Prices for: <span class="text-primary">@product?.Name</span></h5>
        @if (product?.LowestPrice.HasValue == true)
        {
            <small class="text-muted">Current range: ₹@product.LowestPrice?.ToString("N0") – ₹@product.HighestPrice?.ToString("N0")</small>
        }
    </div>
    <a asp-area="Admin" asp-controller="AffiliateLinks" asp-action="Create" asp-route-productId="@product?.Id"
       class="btn btn-primary ms-auto">
        <i class="bi bi-plus-circle me-1"></i> Add Price Link
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <i class="bi bi-currency-rupee fs-1 text-muted"></i>
        <h4 class="mt-3">No price links yet</h4>
        <p class="text-muted">Add affiliate price links from different stores</p>
        <a asp-area="Admin" asp-controller="AffiliateLinks" asp-action="Create" asp-route-productId="@product?.Id"
           class="btn btn-primary mx-auto" style="width:200px;">Add First Price</a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Store</th><th>Price (₹)</th><th>MRP (₹)</th><th>Discount</th><th>Currency</th><th>Stock</th><th>Active</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var link in Model.OrderBy(l => l.Price))
                    {
                        <tr>
                            <td class="fw-semibold">@(link.Store?.Name ?? link.StoreId)</td>
                            <td>
                                @if (link.Price.HasValue)
                                {
                                    <strong class="text-success">₹@link.Price.Value.ToString("N0")</strong>
                                }
                                else { <span class="text-muted">-</span> }
                            </td>
                            <td>
                                @if (link.Mrp.HasValue)
                                {
                                    <span class="text-muted text-decoration-line-through">₹@link.Mrp.Value.ToString("N0")</span>
                                }
                            </td>
                            <td>
                                @if (link.DiscountPercent.HasValue)
                                {
                                    <span class="badge bg-success">@link.DiscountPercent%</span>
                                }
                            </td>
                            <td><small class="text-muted">@link.Currency</small></td>
                            <td>
                                <span class="badge @(link.InStock ? "bg-success" : "bg-danger")">
                                    @(link.InStock ? "In Stock" : "Out of Stock")
                                </span>
                            </td>
                            <td><span class="badge @(link.IsActive ? "bg-success" : "bg-secondary")">@(link.IsActive ? "On" : "Off")</span></td>
                            <td>
                                <a asp-area="Admin" asp-controller="AffiliateLinks" asp-action="Edit" asp-route-id="@link.Id"
                                   class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <a href="@link.AffiliateUrl" target="_blank" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                                <form asp-area="Admin" asp-controller="AffiliateLinks" asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this price link?')">
                                    <input type="hidden" name="id" value="@link.Id" />
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
