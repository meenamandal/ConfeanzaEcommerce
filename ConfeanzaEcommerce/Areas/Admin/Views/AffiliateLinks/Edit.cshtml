@model AffiliateLink
@{
    ViewData["Title"] = "Edit Price Link";
    var product = ViewBag.Product as Product;
    var stores = ViewBag.Stores as List<Store> ?? new();
}

<a asp-area="Admin" asp-controller="AffiliateLinks" asp-action="Index" asp-route-productId="@Model.ProductId"
   class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left"></i> Back to Prices
</a>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold">
        Edit Price for: <span class="text-primary">@product?.Name</span>
    </div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="AffiliateLinks" asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Store *</label>
                    <select name="StoreId" class="form-select" required>
                        @foreach (var s in stores)
                        {
                            <option value="@s.Id" selected="@(Model.StoreId == s.Id ? "selected" : null)">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Current Price (₹)</label>
                    <input name="Price" type="number" step="0.01" class="form-control" value="@Model.Price" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">MRP (₹)</label>
                    <input name="Mrp" type="number" step="0.01" class="form-control" value="@Model.Mrp" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Discount (%)</label>
                    <input name="DiscountPercent" type="number" step="0.01" class="form-control" value="@Model.DiscountPercent" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Commission Rate (%)</label>
                    <input name="CommissionRate" type="number" step="0.01" class="form-control" value="@Model.CommissionRate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Currency</label>
                    <select name="Currency" class="form-select">
                        <option value="INR" selected="@(Model.Currency == "INR" ? "selected" : null)">INR (₹)</option>
                        <option value="USD" selected="@(Model.Currency == "USD" ? "selected" : null)">USD ($)</option>
                        <option value="GBP" selected="@(Model.Currency == "GBP" ? "selected" : null)">GBP (£)</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Affiliate URL *</label>
                    <input name="AffiliateUrl" class="form-control" value="@Model.AffiliateUrl" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Original Product URL</label>
                    <input name="OriginalUrl" class="form-control" value="@Model.OriginalUrl" />
                </div>
                <div class="col-12 d-flex gap-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="InStock" value="true" @(Model.InStock ? "checked" : "") />
                        <label class="form-check-label fw-semibold">In Stock</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") />
                        <label class="form-check-label fw-semibold">Active</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Save</button>
                    <a asp-area="Admin" asp-controller="AffiliateLinks" asp-action="Index" asp-route-productId="@Model.ProductId"
                       class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
