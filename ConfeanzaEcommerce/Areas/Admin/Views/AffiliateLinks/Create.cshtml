@model AffiliateLink
@{
    ViewData["Title"] = "Add Price Link";
    var product = ViewBag.Product as Product;
    var stores = ViewBag.Stores as List<Store> ?? new();
}

<a asp-area="Admin" asp-controller="AffiliateLinks" asp-action="Index" asp-route-productId="@Model.ProductId"
   class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left"></i> Back to Prices
</a>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold">
        Add Price Link for: <span class="text-primary">@product?.Name</span>
    </div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="AffiliateLinks" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ProductId" value="@Model.ProductId" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Store *</label>
                    <select name="StoreId" class="form-select" required>
                        <option value="">-- Select Store --</option>
                        @foreach (var s in stores) { <option value="@s.Id">@s.Name</option> }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Current Price (₹)</label>
                    <input name="Price" type="number" step="0.01" class="form-control" placeholder="e.g. 29999" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">MRP / Original Price (₹)</label>
                    <input name="Mrp" type="number" step="0.01" class="form-control" placeholder="e.g. 39999" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Discount (%)</label>
                    <input name="DiscountPercent" type="number" step="0.01" class="form-control" placeholder="Auto-calc or override" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Commission Rate (%)</label>
                    <input name="CommissionRate" type="number" step="0.01" class="form-control" placeholder="e.g. 5" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Currency</label>
                    <select name="Currency" class="form-select">
                        <option value="INR">INR (₹)</option>
                        <option value="USD">USD ($)</option>
                        <option value="GBP">GBP (£)</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Affiliate URL * <small class="text-muted">(tracking link for this store)</small></label>
                    <input name="AffiliateUrl" class="form-control" required placeholder="https://amzn.to/..." />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Original Product URL</label>
                    <input name="OriginalUrl" class="form-control" placeholder="https://www.amazon.in/product..." />
                </div>
                <div class="col-12 d-flex gap-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="InStock" value="true" checked />
                        <label class="form-check-label fw-semibold">In Stock</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                        <label class="form-check-label fw-semibold">Active</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-circle me-1"></i> Add Price</button>
                    <a asp-area="Admin" asp-controller="AffiliateLinks" asp-action="Index" asp-route-productId="@Model.ProductId"
                       class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
