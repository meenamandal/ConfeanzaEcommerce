@model Blog
@{
    ViewData["Title"] = "Edit Blog Post";
}

<a asp-area="Admin" asp-controller="Blogs" asp-action="Index" class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left"></i> Back
</a>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-bold">Edit Post</span>
        <a asp-controller="Blogs" asp-action="Details" asp-route-slug="@Model.Slug" asp-area=""
           class="btn btn-sm btn-outline-secondary" target="_blank">
            <i class="bi bi-eye"></i> Preview
        </a>
    </div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Blogs" asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">Title *</label>
                    <input name="Title" class="form-control form-control-lg" value="@Model.Title" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Category</label>
                    <input name="Category" class="form-control" value="@Model.Category" list="blogCats" />
                    <datalist id="blogCats">
                        <option value="Reviews" /><option value="Buying Guide" /><option value="Deals" /><option value="Tips & Tricks" /><option value="Comparison" /><option value="News" />
                    </datalist>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Status</label>
                    <select name="Status" class="form-select">
                        <option value="draft" selected="@(Model.Status == "draft")">Draft</option>
                        <option value="published" selected="@(Model.Status == "published")">Published</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Read Time (minutes)</label>
                    <input name="ReadTime" type="number" class="form-control" value="@Model.ReadTime" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Excerpt</label>
                    <textarea name="Excerpt" class="form-control" rows="2">@Model.Excerpt</textarea>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Cover Image URL</label>
                    <input name="CoverImage" class="form-control" value="@Model.CoverImage" id="coverImgInput" oninput="previewCover(this.value)" />
                    <img id="coverPreview" src="@Model.CoverImage" class="mt-2 img-fluid rounded"
                         style="max-height:150px;@(string.IsNullOrEmpty(Model.CoverImage) ? "display:none;" : "")" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Content *</label>
                    <textarea name="Content" class="form-control" rows="20" required>@Model.Content</textarea>
                    <small class="text-muted">HTML supported: &lt;h2&gt;, &lt;p&gt;, &lt;strong&gt;, &lt;ul&gt;, etc.</small>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Meta Title</label>
                    <input name="MetaTitle" class="form-control" value="@Model.MetaTitle" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Meta Description</label>
                    <input name="MetaDescription" class="form-control" value="@Model.MetaDescription" />
                </div>
                <div class="col-12 d-flex gap-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsFeatured" value="true" @(Model.IsFeatured ? "checked" : "") />
                        <label class="form-check-label fw-semibold">Featured Post</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-1"></i> Save</button>
                    <a asp-area="Admin" asp-controller="Blogs" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function previewCover(url) {
    var img = document.getElementById('coverPreview');
    if (url) { img.src = url; img.style.display = 'block'; }
    else { img.style.display = 'none'; }
}
</script>
}
