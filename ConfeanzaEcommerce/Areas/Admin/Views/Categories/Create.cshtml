@model Category
@{
    ViewData["Title"] = "Add Category";
}

<a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left"></i> Back
</a>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Categories" asp-action="Create"
              method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Category Name *</label>
                    <input name="Name" class="form-control" required placeholder="e.g. Electronics" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Sort Order</label>
                    <input name="SortOrder" type="number" class="form-control" value="0" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Category Image</label>
                    <div class="d-flex align-items-start gap-3 flex-wrap">
                        <div style="width:100px;height:100px;border:2px dashed #f9a8d4;border-radius:12px;background:#fdf4ff;overflow:hidden;flex-shrink:0;">
                            <img id="imgPreview" src="/uploads/categories/placeholder.svg" alt="Preview"
                                 style="width:100%;height:100%;object-fit:contain;" />
                        </div>
                        <div class="flex-grow-1">
                            <input type="file" name="imageFile" class="form-control"
                                   accept=".jpg,.jpeg,.png,.webp,.svg" onchange="previewImg(this)" />
                            <div class="form-text">JPG, PNG, WebP or SVG. This image appears on the Shop by Category page and in the navbar dropdown.</div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Meta Title</label>
                    <input name="MetaTitle" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Meta Description</label>
                    <input name="MetaDescription" class="form-control" />
                </div>
                <div class="col-12">
                    <div class="d-flex gap-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                            <label class="form-check-label fw-semibold">Active</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="IsFeatured" value="true" />
                            <label class="form-check-label fw-semibold">Featured on Homepage</label>
                        </div>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle me-1"></i> Create Category
                    </button>
                    <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function previewImg(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => document.getElementById('imgPreview').src = e.target.result;
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
}
