@model Category
@{
    ViewData["Title"] = "Edit Category";
    var currentImg = !string.IsNullOrEmpty(Model.ImageUrl)
        ? Model.ImageUrl : "/uploads/categories/placeholder.svg";
}

<a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left"></i> Back
</a>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold">Edit: @Model.Name</div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Categories" asp-action="Edit"
              asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Category Name *</label>
                    <input name="Name" class="form-control" value="@Model.Name" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Sort Order</label>
                    <input name="SortOrder" type="number" class="form-control" value="@Model.SortOrder" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Category Image</label>
                    <div class="d-flex align-items-start gap-3 flex-wrap">
                        <div style="width:100px;height:100px;border:2px solid #f9a8d4;border-radius:12px;background:#fdf4ff;overflow:hidden;flex-shrink:0;">
                            <img id="imgPreview" src="@currentImg" alt="@Model.Name"
                                 style="width:100%;height:100%;object-fit:contain;" />
                        </div>
                        <div class="flex-grow-1">
                            <input type="file" name="imageFile" class="form-control"
                                   accept=".jpg,.jpeg,.png,.webp,.svg" onchange="previewImg(this)" />
                            <div class="form-text">
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <span class="text-success"><i class="bi bi-check-circle me-1"></i>Image uploaded — select a new file to replace it.</span>
                                }
                                else
                                {
                                    <span>JPG, PNG, WebP or SVG. Shown on the Shop by Category page and navbar dropdown.</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Meta Title</label>
                    <input name="MetaTitle" class="form-control" value="@Model.MetaTitle" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Meta Description</label>
                    <input name="MetaDescription" class="form-control" value="@Model.MetaDescription" />
                </div>

                <!-- Category-wise Notice -->
                <div class="col-12">
                    <div class="p-3 rounded-3" style="background:#fff8e1;border:1px solid #ffe082;">
                        <label class="form-label fw-semibold mb-1" style="color:#7c5700;">
                            <i class="bi bi-info-circle-fill me-1" style="color:#f59e0b;"></i>
                            Product Page Notice <span class="fw-normal text-muted">(Optional)</span>
                        </label>
                        <textarea name="PageNotice" class="form-control" rows="2"
                                  placeholder="e.g. Select your preferred size and colour on the store before purchasing."
                                  style="border-color:#ffe082;">@Model.PageNotice</textarea>
                        <div class="form-text mt-1" style="color:#92400e;">
                            If filled, this notice will appear on all product pages in this category — but <strong>only when the "Visit Store" button is enabled</strong> for a product. Leave blank to show no notice.
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="d-flex gap-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="IsActive" value="true"
                                   @(Model.IsActive ? "checked" : "") />
                            <label class="form-check-label fw-semibold">Active</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="IsFeatured" value="true"
                                   @(Model.IsFeatured ? "checked" : "") />
                            <label class="form-check-label fw-semibold">Featured</label>
                        </div>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle me-1"></i> Save Changes
                    </button>
                    <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function previewImg(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => document.getElementById('imgPreview').src = e.target.result;
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
}
