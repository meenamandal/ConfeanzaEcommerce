@model List<Category>
@{
    ViewData["Title"] = "Categories";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted mb-0">@Model.Count total categories</p>
    <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Add Category
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Slug</th>
                    <th>Sort</th>
                    <th>Active</th>
                    <th>Featured</th>
                    <th>Subcategories</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td>
                            <img src="@(!string.IsNullOrEmpty(cat.ImageUrl) ? cat.ImageUrl : "/uploads/categories/placeholder.svg")"
                                 alt="@cat.Name" style="width:48px;height:48px;object-fit:contain;border-radius:8px;background:#fdf4ff;" />
                        </td>
                        <td class="fw-semibold">@cat.Name</td>
                        <td><code class="small">@cat.Slug</code></td>
                        <td>@cat.SortOrder</td>
                        <td>
                            <span class="badge @(cat.IsActive ? "bg-success" : "bg-secondary")">
                                @(cat.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            @if (cat.IsFeatured) { <span class="badge bg-warning text-dark">Featured</span> }
                        </td>
                        <td><small class="text-muted">@cat.Subcategories.Count</small></td>
                        <td>
                            <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@cat.Id"
                               class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form asp-area="Admin" asp-controller="Categories" asp-action="Delete" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete category @cat.Name?')">
                                <input type="hidden" name="id" value="@cat.Id" />
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
