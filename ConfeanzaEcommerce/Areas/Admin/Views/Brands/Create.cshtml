@model Brand
@{
    ViewData["Title"] = "Add Brand";
}

<a asp-area="Admin" asp-controller="Brands" asp-action="Index" class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left"></i> Back
</a>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Brands" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Brand Name *</label>
                    <input name="Name" class="form-control" required placeholder="e.g. Samsung" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Country</label>
                    <input name="Country" class="form-control" placeholder="e.g. South Korea" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Logo URL</label>
                    <input name="LogoUrl" class="form-control" placeholder="https://..." />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Website URL</label>
                    <input name="WebsiteUrl" class="form-control" placeholder="https://samsung.com" />
                </div>
                <div class="col-12 d-flex gap-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                        <label class="form-check-label fw-semibold">Active</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsFeatured" value="true" />
                        <label class="form-check-label fw-semibold">Featured</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Create Brand</button>
                    <a asp-area="Admin" asp-controller="Brands" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
