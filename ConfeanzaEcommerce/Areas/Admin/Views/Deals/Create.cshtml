@model Deal
@{
    ViewData["Title"] = "Add Deal";
    var stores = ViewBag.Stores as List<Store> ?? new();
}

<a asp-area="Admin" asp-controller="Deals" asp-action="Index" class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left"></i> Back
</a>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Deals" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Deal Title *</label>
                    <input name="Title" class="form-control" required placeholder="e.g. Amazon Great Indian Sale - Up to 80% Off" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Deal Type</label>
                    <select name="DealType" class="form-select">
                        <option value="daily_deal">Daily Deal</option>
                        <option value="flash_sale">Flash Sale</option>
                        <option value="clearance">Clearance</option>
                        <option value="seasonal">Seasonal Sale</option>
                        <option value="bank_offer">Bank Offer</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Store</label>
                    <select name="StoreId" class="form-select">
                        <option value="">-- No Specific Store --</option>
                        @foreach (var s in stores)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Discount (%)</label>
                    <input name="DiscountPercent" type="number" step="0.01" class="form-control" placeholder="e.g. 80" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="Description" class="form-control" rows="3" placeholder="Deal details..."></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Affiliate URL</label>
                    <input name="AffiliateUrl" class="form-control" placeholder="https://..." />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Banner Image URL</label>
                    <input name="BannerImage" class="form-control" placeholder="https://..." />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Start Date</label>
                    <input name="StartsAt" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Expiry Date</label>
                    <input name="ExpiresAt" type="datetime-local" class="form-control" />
                </div>
                <div class="col-12 d-flex gap-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                        <label class="form-check-label fw-semibold">Active</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsFeatured" value="true" />
                        <label class="form-check-label fw-semibold">Featured</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Create Deal</button>
                    <a asp-area="Admin" asp-controller="Deals" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
