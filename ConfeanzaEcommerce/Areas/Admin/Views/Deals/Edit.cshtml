@model Deal
@{
    ViewData["Title"] = "Edit Deal";
    var stores = ViewBag.Stores as List<Store> ?? new();
}

<a asp-area="Admin" asp-controller="Deals" asp-action="Index" class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left"></i> Back
</a>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold">Edit Deal</div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Deals" asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Deal Title *</label>
                    <input name="Title" class="form-control" value="@Model.Title" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Deal Type</label>
                    <select name="DealType" class="form-select">
                        @foreach (var t in new[]{"daily_deal","flash_sale","clearance","seasonal","bank_offer"})
                        {
                            <option value="@t" selected="@(Model.DealType == t)">@t.Replace("_"," ").ToUpper()</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Store</label>
                    <select name="StoreId" class="form-select">
                        <option value="">-- No Specific Store --</option>
                        @foreach (var s in stores)
                        {
                            <option value="@s.Id" selected="@(Model.StoreId == s.Id)">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Discount (%)</label>
                    <input name="DiscountPercent" type="number" step="0.01" class="form-control" value="@Model.DiscountPercent" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Affiliate URL</label>
                    <input name="AffiliateUrl" class="form-control" value="@Model.AffiliateUrl" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Banner Image URL</label>
                    <input name="BannerImage" class="form-control" value="@Model.BannerImage" />
                    @if (!string.IsNullOrEmpty(Model.BannerImage)) { <img src="@Model.BannerImage" class="mt-2 img-fluid" style="max-height:100px;" /> }
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Start Date</label>
                    <input name="StartsAt" type="datetime-local" class="form-control" value="@Model.StartsAt.ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Expiry Date</label>
                    <input name="ExpiresAt" type="datetime-local" class="form-control" value="@Model.ExpiresAt?.ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-12 d-flex gap-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") />
                        <label class="form-check-label fw-semibold">Active</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsFeatured" value="true" @(Model.IsFeatured ? "checked" : "") />
                        <label class="form-check-label fw-semibold">Featured</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Save</button>
                    <a asp-area="Admin" asp-controller="Deals" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
