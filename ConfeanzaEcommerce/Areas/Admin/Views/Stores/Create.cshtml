@model Store
@{
    ViewData["Title"] = "Add Store";
}

<a asp-area="Admin" asp-controller="Stores" asp-action="Index" class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left"></i> Back
</a>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Stores" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Store Name *</label>
                    <input name="Name" class="form-control" required placeholder="e.g. Amazon India" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Affiliate Network *</label>
                    <select name="AffiliateNetwork" class="form-select">
                        <option value="amazon">Amazon Associates</option>
                        <option value="flipkart">Flipkart Affiliate</option>
                        <option value="cj">Commission Junction</option>
                        <option value="impact">Impact Radius</option>
                        <option value="direct">Direct</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Website URL *</label>
                    <input name="WebsiteUrl" class="form-control" required placeholder="https://amazon.in" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Tracking ID</label>
                    <input name="TrackingId" class="form-control" placeholder="your-tracking-id" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Commission Rate (%)</label>
                    <input name="CommissionRate" type="number" step="0.01" class="form-control" placeholder="0.00" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Cookie Duration (days)</label>
                    <input name="CookieDuration" type="number" class="form-control" placeholder="30" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Sort Order</label>
                    <input name="SortOrder" type="number" class="form-control" value="0" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Logo URL</label>
                    <input name="LogoUrl" class="form-control" placeholder="https://..." />
                </div>
                <div class="col-12 d-flex gap-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                        <label class="form-check-label fw-semibold">Active</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsFeatured" value="true" />
                        <label class="form-check-label fw-semibold">Featured</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Create Store</button>
                    <a asp-area="Admin" asp-controller="Stores" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
