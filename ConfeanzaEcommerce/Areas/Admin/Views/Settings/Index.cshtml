@model SiteSettings
@{
    ViewData["Title"] = "Site Settings";
    var hasNotice = !string.IsNullOrWhiteSpace(Model.ProductPageNotice);
}

<div class="row g-4">
    <div class="col-lg-8">
        <form asp-area="Admin" asp-controller="Settings" asp-action="Index" method="post">
            @Html.AntiForgeryToken()

            <!-- Product Page Notice -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="fw-bold mb-0">Product Page Notice</h6>
                        <small class="text-muted">Displayed above the store button on every product page</small>
                    </div>
                    <span class="badge @(hasNotice ? "bg-success" : "bg-secondary")">
                        @(hasNotice ? "Active" : "Off")
                    </span>
                </div>
                <div class="card-body">
                    <label class="form-label fw-semibold">Notice Message <span class="text-muted fw-normal">(optional)</span></label>
                    <textarea name="ProductPageNotice" class="form-control" rows="3"
                              placeholder="e.g. Select your preferred size, color, and other available options on the selected store before purchasing.">@Model.ProductPageNotice</textarea>
                    <div class="form-text mt-2">
                        <i class="bi bi-info-circle me-1"></i>
                        Leave empty to disable. When set, the <strong>Buy Now</strong> button becomes <strong>Visit Store</strong> and this message appears above it.
                    </div>

                    <!-- Live Preview -->
                    @if (hasNotice)
                    {
                        <div class="mt-3 p-2 rounded" style="background:#fff8e1;border:1px solid #ffe082;">
                            <small class="text-muted d-block mb-1">Preview on product page:</small>
                            <div class="d-flex align-items-start gap-2" style="color:#7c5700;">
                                <i class="bi bi-info-circle-fill mt-1 flex-shrink-0" style="color:#f59e0b;"></i>
                                <span class="small">@Model.ProductPageNotice</span>
                            </div>
                            <div class="mt-2">
                                <button type="button" class="btn btn-primary btn-sm fw-semibold" disabled>
                                    Visit Store <i class="bi bi-arrow-right"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-check-circle me-1"></i> Save Settings
                </button>
                @if (hasNotice)
                {
                    <button type="submit" name="ProductPageNotice" value=""
                            class="btn btn-outline-secondary"
                            onclick="this.form.querySelector('[name=ProductPageNotice]').value=''">
                        <i class="bi bi-x-circle me-1"></i> Clear Notice
                    </button>
                }
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-lightbulb text-warning me-2"></i>How it works</h6>
                <ul class="small text-muted ps-3 mb-0">
                    <li class="mb-2"><strong>Notice empty</strong> — product page shows <span class="badge bg-warning text-dark">Buy Now →</span> button as usual</li>
                    <li class="mb-2"><strong>Notice set</strong> — your message appears above the button and <span class="badge bg-primary">Visit Store →</span> replaces Buy Now on all products</li>
                    <li>Changes take effect immediately — no restart needed</li>
                </ul>
            </div>
        </div>
    </div>
</div>
