@model Coupon
@{
    ViewData["Title"] = "Edit Coupon";
    var stores = ViewBag.Stores as List<Store> ?? new();
}

<a asp-area="Admin" asp-controller="Coupons" asp-action="Index" class="btn btn-outline-secondary btn-sm mb-4">
    <i class="bi bi-arrow-left"></i> Back
</a>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold">Edit: @Model.Code</div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Coupons" asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Coupon Code *</label>
                    <input name="Code" class="form-control text-uppercase" value="@Model.Code" required style="font-family:monospace;font-size:1.1rem;" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Store</label>
                    <select name="StoreId" class="form-select">
                        <option value="">-- All Stores --</option>
                        @foreach (var s in stores) { <option value="@s.Id" selected="@(Model.StoreId == s.Id ? "selected" : null)">@s.Name</option> }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Coupon Type *</label>
                    <select name="Type" class="form-select">
                        @foreach (var t in new[]{"percentage","flat","free_shipping","cashback","bogo"})
                        {
                            <option value="@t" selected="@(Model.Type == t ? "selected" : null)">@t.Replace("_"," ").ToUpper()</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Title *</label>
                    <input name="Title" class="form-control" value="@Model.Title" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="Description" class="form-control" rows="2">@Model.Description</textarea>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Discount Value</label>
                    <input name="DiscountValue" type="number" step="0.01" class="form-control" value="@Model.DiscountValue" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Min. Order Value (₹)</label>
                    <input name="MinOrderValue" type="number" step="0.01" class="form-control" value="@Model.MinOrderValue" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Max Discount (₹)</label>
                    <input name="MaxDiscount" type="number" step="0.01" class="form-control" value="@Model.MaxDiscount" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Affiliate URL</label>
                    <input name="AffiliateUrl" class="form-control" value="@Model.AffiliateUrl" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Valid From</label>
                    <input name="StartsAt" type="datetime-local" class="form-control" value="@Model.StartsAt?.ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Valid Until</label>
                    <input name="ExpiresAt" type="datetime-local" class="form-control" value="@Model.ExpiresAt?.ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-12 d-flex gap-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") />
                        <label class="form-check-label fw-semibold">Active</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsVerified" value="true" @(Model.IsVerified ? "checked" : "") />
                        <label class="form-check-label fw-semibold">Verified</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Save</button>
                    <a asp-area="Admin" asp-controller="Coupons" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
