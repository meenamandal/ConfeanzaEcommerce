@model List<Deal>
@{
    ViewData["Title"] = "Today's Best Deals";
    var selectedType = ViewBag.Type as string;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1"><i class="bi bi-fire text-danger"></i> Today's Deals</h1>
            <p class="text-muted mb-0">Limited-time offers from top stores</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Deals" asp-action="Index" class="btn btn-sm @(selectedType == null ? "btn-primary" : "btn-outline-secondary")">All</a>
            <a asp-controller="Deals" asp-action="Index" asp-route-type="daily_deal" class="btn btn-sm @(selectedType == "daily_deal" ? "btn-primary" : "btn-outline-secondary")">Daily</a>
            <a asp-controller="Deals" asp-action="Index" asp-route-type="flash_sale" class="btn btn-sm @(selectedType == "flash_sale" ? "btn-primary" : "btn-outline-secondary")">Flash Sale</a>
            <a asp-controller="Deals" asp-action="Index" asp-route-type="clearance" class="btn btn-sm @(selectedType == "clearance" ? "btn-primary" : "btn-outline-secondary")">Clearance</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-fire fs-1 text-muted"></i>
            <h4 class="mt-3">No active deals right now</h4>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var deal in Model)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card border-0 shadow-sm h-100 card-hover position-relative">
                        @if (deal.IsFeatured)
                        {
                            <div class="position-absolute top-0 start-0 m-2">
                                <span class="badge bg-warning text-dark"><i class="bi bi-star-fill"></i> Featured</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(deal.BannerImage))
                        {
                            <img src="@deal.BannerImage" class="card-img-top" alt="@deal.Title" style="height:200px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="bg-gradient d-flex align-items-center justify-content-center" style="height:160px;background:linear-gradient(135deg,#f6d365,#fda085);">
                                <i class="bi bi-tag-fill text-white display-3"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@deal.Title</h5>
                            @if (!string.IsNullOrEmpty(deal.Description)) { <p class="card-text text-muted small">@deal.Description</p> }
                            <div class="d-flex align-items-center gap-2 mb-3">
                                @if (deal.DiscountPercent.HasValue)
                                {
                                    <span class="badge bg-danger fs-6">@deal.DiscountPercent% OFF</span>
                                }
                                @if (deal.Store != null)
                                {
                                    <span class="badge bg-light text-dark border">@deal.Store.Name</span>
                                }
                            </div>
                            @if (deal.ExpiresAt.HasValue)
                            {
                                <p class="small text-muted mb-2"><i class="bi bi-alarm"></i> Expires @deal.ExpiresAt.Value.ToString("MMM dd, yyyy HH:mm")</p>
                            }
                            @if (!string.IsNullOrEmpty(deal.AffiliateUrl))
                            {
                                <a href="@deal.AffiliateUrl" target="_blank" rel="nofollow noopener" class="btn btn-warning w-100 fw-bold">
                                    <i class="bi bi-arrow-right-circle me-1"></i> Grab This Deal
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
