@model List<Coupon>
@{
    ViewData["Title"] = "Coupons & Promo Codes";
    var stores = ViewBag.Stores as List<Store> ?? new();
    var selectedStore = ViewBag.SelectedStore as string;
    var selectedType = ViewBag.SelectedType as string;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1"><i class="bi bi-ticket-perforated text-info"></i> Coupons & Promo Codes</h1>
            <p class="text-muted mb-0">Verified discount codes for all top stores</p>
        </div>
    </div>

    <!-- Filters -->
    <form asp-controller="Coupons" asp-action="Index" method="get" class="card border-0 shadow-sm mb-4 p-3">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Filter by Store</label>
                <select name="store" class="form-select" onchange="this.form.submit()">
                    <option value="">All Stores</option>
                    @foreach (var store in stores)
                    {
                        <option value="@store.Slug" selected="@(selectedStore == store.Slug)">@store.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Coupon Type</label>
                <select name="type" class="form-select" onchange="this.form.submit()">
                    <option value="">All Types</option>
                    <option value="percentage" selected="@(selectedType == "percentage")">Percentage Discount</option>
                    <option value="flat" selected="@(selectedType == "flat")">Flat Discount</option>
                    <option value="free_shipping" selected="@(selectedType == "free_shipping")">Free Shipping</option>
                    <option value="cashback" selected="@(selectedType == "cashback")">Cashback</option>
                </select>
            </div>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-ticket-perforated fs-1 text-muted"></i>
            <h4 class="mt-3">No coupons found</h4>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var coupon in Model)
            {
                <div class="col-md-4">
                    <div class="card border-2 @(coupon.IsVerified ? "border-success" : "border-light") h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    @if (coupon.Store != null)
                                    {
                                        <span class="badge bg-primary mb-1">@coupon.Store.Name</span>
                                    }
                                    <h6 class="fw-bold mb-0">@coupon.Title</h6>
                                </div>
                                @if (coupon.IsVerified)
                                {
                                    <span class="badge bg-success"><i class="bi bi-patch-check-fill"></i> Verified</span>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(coupon.Description))
                            {
                                <p class="text-muted small mb-2">@coupon.Description</p>
                            }

                            <div class="d-flex align-items-center gap-2 mb-2">
                                @if (coupon.Type == "percentage")
                                {
                                    <span class="badge bg-warning text-dark fs-6">@coupon.DiscountValue% OFF</span>
                                }
                                else if (coupon.Type == "flat")
                                {
                                    <span class="badge bg-warning text-dark fs-6">₹@coupon.DiscountValue.ToString("N0") OFF</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">@coupon.Type.Replace("_", " ").ToUpper()</span>
                                }
                            </div>

                            @if (coupon.MinOrderValue.HasValue)
                            {
                                <small class="text-muted d-block">Min. order: ₹@coupon.MinOrderValue.Value.ToString("N0")</small>
                            }

                            <div class="d-flex align-items-center gap-2 mt-3">
                                <code class="fs-6 flex-grow-1 bg-light border border-dashed rounded px-2 py-1 text-center">@coupon.Code</code>
                                <button class="btn btn-outline-primary btn-sm" title="Copy code"
                                        onclick="navigator.clipboard.writeText('@coupon.Code'); this.innerHTML='<i class=\'bi bi-check\'></i>'">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            </div>

                            @if (coupon.AffiliateUrl != null)
                            {
                                <a href="@coupon.AffiliateUrl" target="_blank" rel="nofollow noopener"
                                   class="btn btn-warning w-100 mt-2 btn-sm fw-semibold">
                                    Use Coupon <i class="bi bi-arrow-right"></i>
                                </a>
                            }

                            @if (coupon.ExpiresAt.HasValue)
                            {
                                <small class="text-muted d-block mt-2 text-end">
                                    <i class="bi bi-clock"></i> Expires @coupon.ExpiresAt.Value.ToString("MMM dd, yyyy")
                                </small>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
