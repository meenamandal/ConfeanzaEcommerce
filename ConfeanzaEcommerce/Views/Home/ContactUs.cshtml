@{
    ViewData["Title"] = "Contact Us";
}

<!-- Hero -->
<section class="py-5 text-white" style="background:linear-gradient(135deg,#be185d 0%,#ec4899 60%,#f472b6 100%);">
    <div class="container py-3 text-center">
        <span class="badge px-3 py-2 mb-3" style="background:rgba(255,255,255,.18);color:#fce7f3;border:1px solid rgba(255,255,255,.3);border-radius:20px;">
            <i class="bi bi-envelope me-1"></i> Get In Touch
        </span>
        <h1 class="display-5 fw-bold mb-2">Contact Us</h1>
        <p class="lead mb-0" style="color:rgba(255,255,255,.85);">Have a question, a deal tip, or partnership enquiry? We'd love to hear from you.</p>
    </div>
</section>

<section class="py-5" style="background:#fdf2f8;">
    <div class="container">
        <div class="row g-4">

            <!-- Contact Form -->
            <div class="col-lg-7">
                <div class="bg-white rounded-3 p-4 p-md-5 shadow-sm" style="border:1px solid #fce7f3;">
                    <h4 class="fw-bold mb-1" style="color:#1e1b4b;">Send Us a Message</h4>
                    <p class="text-muted small mb-4">We reply within 1 business day.</p>

                    @if (TempData["ContactSuccess"] != null)
                    {
                        <div class="alert d-flex align-items-center gap-2 mb-4" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;color:#166534;">
                            <i class="bi bi-check-circle-fill fs-5" style="color:#22c55e;"></i>
                            <span>@TempData["ContactSuccess"]</span>
                        </div>
                    }
                    @if (TempData["ContactError"] != null)
                    {
                        <div class="alert d-flex align-items-center gap-2 mb-4" style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;color:#991b1b;">
                            <i class="bi bi-exclamation-triangle-fill fs-5" style="color:#ef4444;"></i>
                            <span>@TempData["ContactError"]</span>
                        </div>
                    }

                    <form asp-action="ContactUs" asp-controller="Home" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium small" style="color:#374151;">Your Name</label>
                                <input type="text" name="name" class="form-control" placeholder="Rahul Sharma" style="border-color:#f9a8d4;" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small" style="color:#374151;">Email Address</label>
                                <input type="email" name="email" class="form-control" placeholder="rahul@email.com" style="border-color:#f9a8d4;" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium small" style="color:#374151;">Subject</label>
                                <select name="subject" class="form-select" style="border-color:#f9a8d4;" required>
                                    <option value="">Select a topic...</option>
                                    <option>Wrong Price / Deal Info</option>
                                    <option>Coupon Not Working</option>
                                    <option>Partnership / Advertise with Us</option>
                                    <option>Submit a Deal</option>
                                    <option>General Enquiry</option>
                                    <option>Other</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium small" style="color:#374151;">Message</label>
                                <textarea name="message" class="form-control" rows="5" placeholder="Describe your query in detail..." style="border-color:#f9a8d4;resize:none;" required></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn fw-bold px-5 py-2 text-white" style="background:#ec4899;border-color:#ec4899;border-radius:25px;">
                                    <i class="bi bi-send me-2"></i>Send Message
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Contact Info -->
            <div class="col-lg-5 d-flex flex-column gap-3">
                <div class="bg-white rounded-3 p-4 shadow-sm" style="border:1px solid #fce7f3;">
                    <div class="d-flex align-items-center gap-3 mb-1">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;background:#fce7f3;">
                            <i class="bi bi-envelope-fill" style="color:#ec4899;font-size:1.1rem;"></i>
                        </div>
                        <div>
                            <div class="fw-semibold" style="color:#1e1b4b;">Email Us</div>
                            <a href="mailto:confeanzatech.official@gmail.com" class="text-decoration-none small" style="color:#ec4899;">confeanzatech.official@gmail.com</a>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-3 p-4 shadow-sm" style="border:1px solid #fce7f3;">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;background:#fce7f3;">
                            <i class="bi bi-whatsapp" style="color:#ec4899;font-size:1.1rem;"></i>
                        </div>
                        <div>
                            <div class="fw-semibold" style="color:#1e1b4b;">WhatsApp</div>
                            <a href="https://wa.me/15055852851" target="_blank" class="text-decoration-none small" style="color:#ec4899;">Chat with us on WhatsApp</a>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-3 p-4 shadow-sm" style="border:1px solid #fce7f3;">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;background:#fce7f3;">
                            <i class="bi bi-telephone-fill" style="color:#ec4899;font-size:1.1rem;"></i>
                        </div>
                        <div>
                            <div class="fw-semibold" style="color:#1e1b4b;">Call Us</div>
                            <a href="tel:+15055852851" class="text-decoration-none small" style="color:#ec4899;">+1 (505) 585-2851</a>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-3 p-4 shadow-sm" style="border:1px solid #fce7f3;">
                    <div class="fw-semibold mb-2" style="color:#1e1b4b;"><i class="bi bi-clock me-2" style="color:#ec4899;"></i>Response Time</div>
                    <p class="text-muted small mb-0">We respond to all enquiries within <strong>1 business day</strong>. For urgent matters, WhatsApp is the fastest way to reach us.</p>
                </div>

                <div class="bg-white rounded-3 p-4 shadow-sm" style="border:1px solid #fce7f3;">
                    <div class="fw-semibold mb-3" style="color:#1e1b4b;">Follow Us</div>
                    <div class="d-flex gap-3 fs-5">
                        <a href="#" class="text-decoration-none" style="color:#ec4899;"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-decoration-none" style="color:#ec4899;"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-decoration-none" style="color:#ec4899;"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="text-decoration-none" style="color:#ec4899;"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
