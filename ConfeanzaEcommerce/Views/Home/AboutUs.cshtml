@{
    ViewData["Title"] = "About Us";
}

<!-- Hero -->
<section class="py-5 text-white" style="background:linear-gradient(135deg,#be185d 0%,#ec4899 60%,#f472b6 100%);">
    <div class="container py-4 text-center">
        <span class="badge px-3 py-2 mb-3" style="background:rgba(255,255,255,.18);color:#fce7f3;border:1px solid rgba(255,255,255,.3);border-radius:20px;">
            <i class="bi bi-info-circle me-1"></i> About Us
        </span>
        <h1 class="display-5 fw-bold mb-3">India's Smartest Price Comparison Platform</h1>
        <p class="lead mb-0" style="color:rgba(255,255,255,.85);max-width:620px;margin:auto;">
            We help millions of Indians find the best deals, verified coupons, and lowest prices across 100+ top online stores — all in one place.
        </p>
    </div>
</section>

<!-- Mission -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="fw-semibold" style="color:#ec4899;font-size:.85rem;letter-spacing:.08em;text-transform:uppercase;">Our Mission</span>
                <h2 class="fw-bold mt-1 mb-3" style="color:#1e1b4b;">Empowering Smarter Shopping Decisions</h2>
                <p class="text-muted lh-lg">
                    At ConfeanzaEcommerce, we believe every rupee matters. Our mission is to make price comparison effortless — so you never overpay again. We aggregate product listings, prices, coupons, and cashback offers from India's biggest e-commerce platforms and present them in a clean, transparent way.
                </p>
                <p class="text-muted lh-lg">
                    We are an <strong>affiliate marketing platform</strong>. When you click a product link and make a purchase, we may earn a small commission at no extra cost to you. This is how we keep the platform free, fast, and always up to date.
                </p>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#fce7f3;">
                            <i class="bi bi-check2-circle" style="color:#ec4899;"></i>
                        </div>
                        <span class="fw-medium" style="color:#374151;">100% Free to Use</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#fce7f3;">
                            <i class="bi bi-check2-circle" style="color:#ec4899;"></i>
                        </div>
                        <span class="fw-medium" style="color:#374151;">Verified Coupons & Deals</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#fce7f3;">
                            <i class="bi bi-check2-circle" style="color:#ec4899;"></i>
                        </div>
                        <span class="fw-medium" style="color:#374151;">Real-Time Price Tracking</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-4 rounded-3 text-center h-100" style="background:#fdf2f8;border:1px solid #fce7f3;">
                            <div class="fw-bold mb-1" style="font-size:2rem;color:#ec4899;">100+</div>
                            <div class="text-muted small">Partner Stores</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-3 text-center h-100" style="background:#fdf2f8;border:1px solid #fce7f3;">
                            <div class="fw-bold mb-1" style="font-size:2rem;color:#ec4899;">50K+</div>
                            <div class="text-muted small">Products Listed</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-3 text-center h-100" style="background:#fdf2f8;border:1px solid #fce7f3;">
                            <div class="fw-bold mb-1" style="font-size:2rem;color:#ec4899;">₹2Cr+</div>
                            <div class="text-muted small">Savings Generated</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-3 text-center h-100" style="background:#fdf2f8;border:1px solid #fce7f3;">
                            <div class="fw-bold mb-1" style="font-size:2rem;color:#ec4899;">1L+</div>
                            <div class="text-muted small">Happy Shoppers</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Affiliate Disclosure -->
<section class="py-5" style="background:#fdf2f8;">
    <div class="container">
        <div class="text-center mb-5">
            <span class="fw-semibold" style="color:#ec4899;font-size:.85rem;letter-spacing:.08em;text-transform:uppercase;">Transparency First</span>
            <h2 class="fw-bold mt-1" style="color:#1e1b4b;">Affiliate Disclosure</h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="p-4 rounded-3 bg-white" style="border:1px solid #fce7f3;">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 mt-1" style="width:42px;height:42px;background:#fce7f3;">
                            <i class="bi bi-megaphone-fill" style="color:#ec4899;"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-2" style="color:#1e1b4b;">How We Make Money</h5>
                            <p class="text-muted mb-2">
                                ConfeanzaEcommerce participates in affiliate programs with Amazon, Flipkart, Myntra, and other partner stores. When you click a "Buy Now" or "Get Deal" button and complete a purchase, we may earn an affiliate commission.
                            </p>
                            <p class="text-muted mb-0">
                                <strong>This costs you nothing extra.</strong> Prices shown are exactly what you pay on the retailer's website. Our commissions come from the retailer's marketing budget, not your wallet. This revenue helps us maintain, improve, and keep the platform free.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- What We Offer -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <span class="fw-semibold" style="color:#ec4899;font-size:.85rem;letter-spacing:.08em;text-transform:uppercase;">What We Offer</span>
            <h2 class="fw-bold mt-1" style="color:#1e1b4b;">Everything for a Smarter Shopping Experience</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-3 col-sm-6">
                <div class="text-center p-4 rounded-3 h-100" style="background:#fdf2f8;border:1px solid #fce7f3;">
                    <div class="mb-3 fs-2" style="color:#ec4899;"><i class="bi bi-graph-down-arrow"></i></div>
                    <h6 class="fw-bold mb-2" style="color:#1e1b4b;">Price Comparison</h6>
                    <p class="text-muted small mb-0">Compare prices across 100+ stores instantly and always get the best rate.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="text-center p-4 rounded-3 h-100" style="background:#fdf2f8;border:1px solid #fce7f3;">
                    <div class="mb-3 fs-2" style="color:#ec4899;"><i class="bi bi-ticket-perforated"></i></div>
                    <h6 class="fw-bold mb-2" style="color:#1e1b4b;">Verified Coupons</h6>
                    <p class="text-muted small mb-0">Every coupon is hand-tested before listing so you never face an expired code.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="text-center p-4 rounded-3 h-100" style="background:#fdf2f8;border:1px solid #fce7f3;">
                    <div class="mb-3 fs-2" style="color:#ec4899;"><i class="bi bi-fire"></i></div>
                    <h6 class="fw-bold mb-2" style="color:#1e1b4b;">Hot Deals</h6>
                    <p class="text-muted small mb-0">Flash sales, seasonal offers, and limited-time deals curated daily by our team.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="text-center p-4 rounded-3 h-100" style="background:#fdf2f8;border:1px solid #fce7f3;">
                    <div class="mb-3 fs-2" style="color:#ec4899;"><i class="bi bi-journal-text"></i></div>
                    <h6 class="fw-bold mb-2" style="color:#1e1b4b;">Buying Guides</h6>
                    <p class="text-muted small mb-0">Expert blogs and guides to help you pick the right product at the right price.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5 text-white text-center" style="background:linear-gradient(135deg,#be185d,#ec4899);">
    <div class="container">
        <h2 class="fw-bold mb-3">Start Saving Today</h2>
        <p class="mb-4" style="color:rgba(255,255,255,.85);">Join lakhs of smart shoppers who trust ConfeanzaEcommerce for the best prices every day.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-light fw-bold px-5 py-2" style="border-radius:25px;color:#be185d;">
            <i class="bi bi-search me-2"></i>Browse Deals
        </a>
    </div>
</section>
