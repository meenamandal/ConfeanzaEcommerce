@model Blog
@{
    ViewData["Title"] = Model.Title;
    var recentBlogs = ViewBag.RecentBlogs as List<Blog> ?? new();
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Blogs" asp-action="Index">Blog</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-md-8">
            <article>
                @if (!string.IsNullOrEmpty(Model.Category))
                {
                    <span class="badge bg-primary mb-3">@Model.Category</span>
                }
                <h1 class="fw-bold mb-3">@Model.Title</h1>
                <div class="d-flex align-items-center gap-3 text-muted small mb-4">
                    @if (Model.PublishedAt.HasValue) { <span><i class="bi bi-calendar3"></i> @Model.PublishedAt.Value.ToString("MMMM dd, yyyy")</span> }
                    @if (Model.ReadTime.HasValue) { <span><i class="bi bi-clock"></i> @Model.ReadTime min read</span> }
                    <span><i class="bi bi-eye"></i> @Model.ViewCount views</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.CoverImage))
                {
                    <img src="@Model.CoverImage" alt="@Model.Title" class="img-fluid rounded mb-4 w-100" style="max-height:400px;object-fit:cover;" />
                }

                <div class="blog-content">
                    @Html.Raw(Model.Content)
                </div>
            </article>
        </div>

        <div class="col-md-4">
            @if (recentBlogs.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-primary text-white fw-semibold">Recent Posts</div>
                    <div class="card-body p-0">
                        @foreach (var rb in recentBlogs)
                        {
                            <a asp-controller="Blogs" asp-action="Details" asp-route-slug="@rb.Slug" class="d-flex gap-3 p-3 text-decoration-none border-bottom hover-bg">
                                @if (!string.IsNullOrEmpty(rb.CoverImage))
                                {
                                    <img src="@rb.CoverImage" alt="" style="width:60px;height:60px;object-fit:cover;border-radius:4px;" />
                                }
                                <div>
                                    <p class="mb-0 small fw-semibold text-dark lh-sm">@rb.Title</p>
                                    @if (rb.PublishedAt.HasValue) { <small class="text-muted">@rb.PublishedAt.Value.ToString("MMM dd")</small> }
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
