@model ProductListViewModel
@{
    ViewData["Title"] = string.IsNullOrEmpty(Model.SearchTerm) ? "All Products" : $"Search: {Model.SearchTerm}";
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active">Products</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Sidebar Filters -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white fw-semibold">Filters</div>
                <div class="card-body">
                    <form asp-controller="Products" asp-action="Index" method="get">
                        @if (!string.IsNullOrEmpty(Model.SearchTerm))
                        {
                            <input type="hidden" name="q" value="@Model.SearchTerm" />
                        }

                        <h6 class="fw-semibold">Category</h6>
                        <select name="category" class="form-select form-select-sm mb-3" onchange="this.form.submit()">
                            <option value="">All Categories</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Slug" selected="@(Model.CategorySlug == cat.Slug)">@cat.Name</option>
                            }
                        </select>

                        <h6 class="fw-semibold">Brand</h6>
                        <select name="brand" class="form-select form-select-sm mb-3" onchange="this.form.submit()">
                            <option value="">All Brands</option>
                            @foreach (var brand in Model.Brands)
                            {
                                <option value="@brand.Slug" selected="@(Model.BrandSlug == brand.Slug)">@brand.Name</option>
                            }
                        </select>

                        <h6 class="fw-semibold">Sort By</h6>
                        <select name="sort" class="form-select form-select-sm" onchange="this.form.submit()">
                            <option value="newest" selected="@(Model.SortBy == "newest")">Newest</option>
                            <option value="popular" selected="@(Model.SortBy == "popular")">Most Popular</option>
                            <option value="rating" selected="@(Model.SortBy == "rating")">Top Rated</option>
                            <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Price: Low to High</option>
                            <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Price: High to Low</option>
                        </select>
                    </form>
                </div>
            </div>
        </div>

        <!-- Products Grid -->
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <p class="text-muted mb-0">Showing @Model.Products.Count of @Model.TotalCount products</p>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <span>Results for: <strong>"@Model.SearchTerm"</strong></span>
                }
            </div>

            @if (!Model.Products.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-search fs-1 text-muted"></i>
                    <h4 class="mt-3">No products found</h4>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-2">Browse All Products</a>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var product in Model.Products)
                    {
                        var img = product.Images.FirstOrDefault(i => i.IsPrimary) ?? product.Images.FirstOrDefault();
                        var bestPrice = product.AffiliateLinks.Where(a => a.IsActive && a.InStock && a.Price.HasValue).OrderBy(a => a.Price).FirstOrDefault();
                        <div class="col-6 col-md-4">
                            <a asp-controller="Products" asp-action="Details" asp-route-slug="@product.Slug" class="text-decoration-none">
                                <div class="card border-0 shadow-sm h-100 card-hover">
                                    @if (img != null)
                                    {
                                        <img src="@img.Url" class="card-img-top p-2" alt="@product.Name" style="height:160px;object-fit:contain;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center" style="height:160px;">
                                            <i class="bi bi-image text-muted fs-2"></i>
                                        </div>
                                    }
                                    <div class="card-body">
                                        <p class="small fw-semibold text-dark lh-sm mb-1" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@product.Name</p>
                                        @if (product.Brand != null)
                                        {
                                            <small class="text-muted">@product.Brand.Name</small>
                                        }
                                        @if (bestPrice != null)
                                        {
                                            <div class="mt-1">
                                                <span class="fw-bold text-success">₹@bestPrice.Price?.ToString("N0")</span>
                                                @if (bestPrice.Mrp.HasValue && bestPrice.Mrp > bestPrice.Price)
                                                {
                                                    <small class="text-muted text-decoration-line-through ms-1">₹@bestPrice.Mrp.Value.ToString("N0")</small>
                                                }
                                                @if (bestPrice.DiscountPercent.HasValue)
                                                {
                                                    <span class="badge bg-success ms-1">@bestPrice.DiscountPercent%OFF</span>
                                                }
                                            </div>
                                        }
                                        @if (product.AffiliateLinks.Count > 1)
                                        {
                                            <small class="text-primary"><i class="bi bi-bar-chart-line"></i> @product.AffiliateLinks.Count stores</small>
                                        }
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link" asp-controller="Products" asp-action="Index"
                                       asp-route-q="@Model.SearchTerm" asp-route-category="@Model.CategorySlug"
                                       asp-route-brand="@Model.BrandSlug" asp-route-sort="@Model.SortBy"
                                       asp-route-page="@i">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>
