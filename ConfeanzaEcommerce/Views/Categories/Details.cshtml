@model Category
@{
    ViewData["Title"] = Model.Name;
    var products = ViewBag.Products as List<Product> ?? new();
    int total = ViewBag.Total ?? 0;
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 24;
    string sort = ViewBag.Sort ?? "newest";
    int totalPages = (int)Math.Ceiling((double)total / pageSize);
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Categories" asp-action="Index">Categories</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0">@Model.Name <small class="text-muted fs-6 fw-normal">(@total products)</small></h1>
        <form asp-controller="Categories" asp-action="Details" asp-route-slug="@Model.Slug" method="get">
            <select name="sort" class="form-select form-select-sm" onchange="this.form.submit()" style="width:180px;">
                <option value="newest" selected="@(sort == "newest")">Newest First</option>
                <option value="popular" selected="@(sort == "popular")">Most Popular</option>
                <option value="rating" selected="@(sort == "rating")">Top Rated</option>
                <option value="price_asc" selected="@(sort == "price_asc")">Price: Low to High</option>
                <option value="price_desc" selected="@(sort == "price_desc")">Price: High to Low</option>
            </select>
        </form>
    </div>

    @if (!products.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-box fs-1 text-muted"></i>
            <h4 class="mt-3">No products in this category yet</h4>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-2">Browse All Products</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var product in products)
            {
                var img = product.Images.FirstOrDefault(i => i.IsPrimary) ?? product.Images.FirstOrDefault();
                var bestPrice = product.AffiliateLinks.Where(a => a.IsActive && a.InStock && a.Price.HasValue).OrderBy(a => a.Price).FirstOrDefault();
                <div class="col-6 col-md-3">
                    <a asp-controller="Products" asp-action="Details" asp-route-slug="@product.Slug" class="text-decoration-none">
                        <div class="card border-0 shadow-sm h-100 card-hover">
                            @if (img != null)
                            {
                                <img src="@img.Url" class="card-img-top p-2" alt="@product.Name" style="height:150px;object-fit:contain;" />
                            }
                            <div class="card-body">
                                <p class="small fw-semibold text-dark lh-sm mb-1" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@product.Name</p>
                                @if (bestPrice != null)
                                {
                                    <span class="fw-bold text-success">₹@bestPrice.Price?.ToString("N0")</span>
                                }
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == page ? "active" : "")">
                            <a class="page-link" asp-controller="Categories" asp-action="Details"
                               asp-route-slug="@Model.Slug" asp-route-sort="@sort" asp-route-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>
